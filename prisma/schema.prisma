generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum WingoRoundStatus {
  OPEN
  LOCKED
  SETTLED
}

enum WingoBetType {
  NUMBER
  COLOR
  SIZE
}

enum WingoBetStatus {
  PENDING
  WON
  LOST
  CANCELLED
}

enum WingoResultMode {
  AUTO
  MANUAL
}

enum GiftClaimStatus {
  SUCCESS
  FAILED
}

enum ActivityTaskPeriod {
  DAILY
  WEEKLY
}

enum RebateClaimStatus {
  PENDING
  CLAIMED
  EXPIRED
}

enum JackpotClaimStatus {
  ELIGIBLE
  CLAIMED
  EXPIRED
}

enum NotificationType {
  LOGIN
  SYSTEM
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

model User {
  id                String                 @id @default(cuid())
  name              String?
  phone             String?                @unique
  email             String?                @unique
  uid               String?                @unique
  inviteCode        String                 @unique
  password          String
  balance           Float                  @default(0.0)
  vipLevel          Int                    @default(0)
  exp               Int                    @default(0)
  role              String                 @default("USER") // USER or ADMIN
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  transactions      Transaction[]
  wingoBets         WingoBet[]
  paymentAccounts   PaymentAccount[]
  giftClaims        GiftClaim[]
  attendanceRecords AttendanceRecord[]
  attendanceClaims  AttendanceClaim[]
  taskProgresses    ActivityTaskProgress[]
  taskClaims        ActivityTaskClaim[]
  rebateClaims      RebateClaim[]
  jackpotClaims     JackpotClaim[]
  notifications     Notification[]
  supportTickets    SupportTicket[]
  downlines         User[]                 @relation("UserToDownlines")
  uplineId          String?
  upline            User?                  @relation("UserToDownlines", fields: [uplineId], references: [id])
}

model PaymentAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  method        String
  accountTitle  String
  accountNumber String?
  accountName   String?
  usdtAddress   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, method])
  @@index([userId, isActive])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // DEPOSIT, WITHDRAW, GAME_WIN, GAME_LOSS, BONUS
  amount    Float
  status    String   @default("COMPLETED") // PENDING, COMPLETED, FAILED
  meta      String?
  createdAt DateTime @default(now())
}

model Banner {
  id          String   @id @default(cuid())
  title       String   @default("")
  image       String
  link        String?
  description String?
  rulesText   String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  placement   String   @default("home")
  createdAt   DateTime @default(now())
}

model Activity {
  id          String   @id @default(cuid())
  title       String
  description String?
  image       String
  type        String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Popup {
  id        String   @id @default(cuid())
  title     String
  content   String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  icon      String
  providers String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Game {
  id        String   @id @default(cuid())
  name      String
  category  String
  image     String
  provider  String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model VipLevel {
  id          String   @id @default(cuid())
  level       Int      @unique
  title       String?
  expRequired Int
  payoutDays  Int      @default(5)
  betToExp    Int      @default(100)
  isOpen      Boolean  @default(true)
  cardImage   String?
  badgeImage  String?
  createdAt   DateTime @default(now())
}

model VipBenefit {
  id             String   @id @default(cuid())
  level          Int
  group          String // LEVEL or MY
  title          String
  description    String?
  image          String
  value          String?
  secondaryValue String?
  order          Int      @default(0)
  createdAt      DateTime @default(now())
}

model SiteConfig {
  id                 String   @id @default(cuid())
  brandName          String   @default("92 Glory0")
  announcement       String?
  announcementButton String?  @default("Detail")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ContentPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PromotionSetting {
  id                   String   @id @default(cuid())
  commissionRate       Float    @default(0.1)
  rebateRate           Float    @default(0.15)
  customerService      String?
  partnerRewardCap     Float    @default(10000)
  invitationBaseUrl    String?
  invitationRulesText  String?
  promotionRulesText   String?
  rebateRatioRulesText String?
  updatedAt            DateTime @updatedAt
}

model GiftCode {
  id             String      @id @default(cuid())
  code           String      @unique
  rewardAmount   Float
  maxTotalClaims Int         @default(1)
  perUserLimit   Int         @default(1)
  expiresAt      DateTime?
  isActive       Boolean     @default(true)
  totalClaimed   Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  claims         GiftClaim[]
}

model GiftClaim {
  id         String          @id @default(cuid())
  giftCodeId String
  giftCode   GiftCode        @relation(fields: [giftCodeId], references: [id], onDelete: Cascade)
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Float
  status     GiftClaimStatus @default(SUCCESS)
  createdAt  DateTime        @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([giftCodeId, createdAt(sort: Desc)])
}

model AttendanceSetting {
  id               String   @id @default(cuid())
  minDepositAmount Float    @default(500)
  oneTimeOnly      Boolean  @default(false)
  day1Reward       Float    @default(15)
  day2Reward       Float    @default(25)
  day3Reward       Float    @default(45)
  day4Reward       Float    @default(85)
  day5Reward       Float    @default(110)
  day6Reward       Float    @default(140)
  day7Reward       Float    @default(180)
  updatedAt        DateTime @updatedAt
}

model AttendanceRecord {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey          String
  consecutiveDays Int      @default(1)
  createdAt       DateTime @default(now())

  @@unique([userId, dayKey])
  @@index([userId, createdAt(sort: Desc)])
}

model AttendanceClaim {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey    String
  dayNumber Int
  amount    Float
  createdAt DateTime @default(now())

  @@unique([userId, dayKey])
  @@index([userId, createdAt(sort: Desc)])
}

model ActivityTask {
  id           String                 @id @default(cuid())
  title        String
  description  String
  gameType     String                 @default("SLOT")
  period       ActivityTaskPeriod     @default(DAILY)
  targetAmount Float
  rewardAmount Float
  order        Int                    @default(0)
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  progresses   ActivityTaskProgress[]
  claims       ActivityTaskClaim[]
}

model ActivityTaskProgress {
  id             String       @id @default(cuid())
  taskId         String
  task           ActivityTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  progressAmount Float        @default(0)
  periodKey      String
  updatedAt      DateTime     @updatedAt
  createdAt      DateTime     @default(now())

  @@unique([taskId, userId, periodKey])
  @@index([userId, periodKey])
}

model ActivityTaskClaim {
  id        String       @id @default(cuid())
  taskId    String
  task      ActivityTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodKey String
  amount    Float
  createdAt DateTime     @default(now())

  @@unique([taskId, userId, periodKey])
  @@index([userId, createdAt(sort: Desc)])
}

model RebateConfig {
  id        String   @id @default(cuid())
  gameType  String
  title     String
  rate      Float
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gameType])
}

model RebateClaim {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameType     String            @default("ALL")
  periodKey    String
  betAmount    Float             @default(0)
  rebateRate   Float             @default(0)
  rebateAmount Float             @default(0)
  status       RebateClaimStatus @default(CLAIMED)
  createdAt    DateTime          @default(now())

  @@unique([userId, gameType, periodKey])
  @@index([userId, createdAt(sort: Desc)])
}

model JackpotSetting {
  id           String   @id @default(cuid())
  minBetAmount Float    @default(10000)
  rewardAmount Float    @default(180)
  validDays    Int      @default(7)
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model JackpotClaim {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodKey      String
  eligibleAmount Float              @default(0)
  rewardAmount   Float
  status         JackpotClaimStatus @default(ELIGIBLE)
  eligibleAt     DateTime           @default(now())
  expiresAt      DateTime?
  claimedAt      DateTime?
  createdAt      DateTime           @default(now())

  @@unique([userId, periodKey])
  @@index([userId, createdAt(sort: Desc)])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(SYSTEM)
  title     String
  content   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

model SupportTicket {
  id            String                    @id @default(cuid())
  userId        String
  user          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      String
  subject       String
  details       String
  status        SupportTicketStatus       @default(OPEN)
  adminResponse String?
  resolvedAt    DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  attachments   SupportTicketAttachment[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
}

model SupportTicketAttachment {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime      @default(now())

  @@index([ticketId, createdAt(sort: Asc)])
}

model PartnerRewardRule {
  id          String   @id @default(cuid())
  stage       String
  minAmount   Float
  maxAmount   Float
  minTurnover Float
  bonusAmount Float
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RebateRatio {
  id        String   @id @default(cuid())
  category  String
  level     Int
  depth     Int
  ratio     Float
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, level, depth])
  @@index([category, level, order])
}

model CustomerServiceLink {
  id        String   @id @default(cuid())
  label     String
  type      String   @default("TELEGRAM")
  url       String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WingoRound {
  id                 String           @id @default(cuid())
  issueNumber        String           @unique
  durationSec        Int
  status             WingoRoundStatus @default(OPEN)
  startsAt           DateTime
  lockAt             DateTime
  endAt              DateTime
  forcedResultNumber Int?
  resultNumber       Int?
  resultColor        String?
  resultSize         String?
  resultMode         WingoResultMode?
  settledAt          DateTime?
  totalBetAmount     Float            @default(0.0)
  totalPayoutAmount  Float            @default(0.0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  bets               WingoBet[]
  result             WingoResult?

  @@index([durationSec, startsAt(sort: Desc)])
  @@index([durationSec, status, endAt])
  @@index([endAt, status])
}

model WingoBet {
  id                 String         @id @default(cuid())
  roundId            String
  round              WingoRound     @relation(fields: [roundId], references: [id], onDelete: Cascade)
  issueNumber        String
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  betType            WingoBetType
  selection          String
  amount             Float
  payoutMultiplier   Float
  potentialWinAmount Float
  status             WingoBetStatus @default(PENDING)
  resultNumber       Int?
  winAmount          Float          @default(0.0)
  settledAt          DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([roundId, status])
  @@index([issueNumber])
}

model WingoResult {
  id           String          @id @default(cuid())
  roundId      String          @unique
  round        WingoRound      @relation(fields: [roundId], references: [id], onDelete: Cascade)
  issueNumber  String
  resultNumber Int
  color        String
  size         String
  mode         WingoResultMode @default(AUTO)
  metadata     String?
  createdAt    DateTime        @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([issueNumber])
}
