generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  name             String?
  phone            String?            @unique
  email            String?            @unique
  uid              String?            @unique
  inviteCode       String             @unique
  password         String
  balance          Float              @default(0.0)
  vipLevel         Int                @default(0)
  exp              Int                @default(0)
  role             String             @default("USER") // USER or ADMIN
  lastLoginAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  transactions     Transaction[]
  depositRequests  DepositRequest[]
  withdrawRequests WithdrawRequest[]
  withdrawAccounts WithdrawAccount[]
  downlines        User[]             @relation("UserToDownlines")
  uplineId         String?
  upline           User?              @relation("UserToDownlines", fields: [uplineId], references: [id])
}

model Transaction {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  type            String // DEPOSIT, WITHDRAW, GAME_WIN, GAME_LOSS, BONUS, MANUAL_ADJUST
  amount          Float
  status          String           @default("COMPLETED") // PENDING, COMPLETED, FAILED
  meta            String?          @db.Text
  createdAt       DateTime         @default(now())
  depositRequest  DepositRequest?
  withdrawRequest WithdrawRequest?

  @@index([userId, type, status, createdAt])
  @@index([status, type, createdAt])
}

model DepositChannel {
  id              String           @id @default(cuid())
  method          String
  title           String
  logo            String
  accountNumber   String
  accountName     String
  instructions    String?          @db.Text
  isActive        Boolean          @default(true)
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  depositRequests DepositRequest[]
}

model DepositRequest {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  channelId     String
  channel       DepositChannel  @relation(fields: [channelId], references: [id])
  amount        Float
  status        String          @default("PENDING") // PENDING, APPROVED, REJECTED
  note          String?         @db.Text
  adminNote     String?         @db.Text
  reviewedBy    String?
  reviewedAt    DateTime?
  transactionId String?         @unique
  transaction   Transaction?    @relation(fields: [transactionId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId, status])
  @@index([channelId, status])
}

model WithdrawAccount {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  method          String
  accountNumber   String
  accountName     String
  title           String?
  isDefault       Boolean           @default(false)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  withdrawRequests WithdrawRequest[]

  @@unique([userId, method])
  @@index([userId, isActive])
}

model WithdrawRequest {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id])
  withdrawAccountId String
  withdrawAccount   WithdrawAccount  @relation(fields: [withdrawAccountId], references: [id])
  amount            Float
  status            String           @default("PENDING") // PENDING, APPROVED, REJECTED
  note              String?          @db.Text
  adminNote         String?          @db.Text
  reviewedBy        String?
  reviewedAt        DateTime?
  transactionId     String?          @unique
  transaction       Transaction?     @relation(fields: [transactionId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId, status])
  @@index([withdrawAccountId, status])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  details    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
}

model Banner {
  id        String   @id @default(cuid())
  image     String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  placement String   @default("home")
  createdAt DateTime @default(now())
}

model Activity {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  image       String
  type        String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Popup {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  icon      String
  providers String?  @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Game {
  id        String   @id @default(cuid())
  name      String
  category  String
  image     String
  provider  String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model VipLevel {
  id          String   @id @default(cuid())
  level       Int      @unique
  title       String?
  expRequired Int
  payoutDays  Int      @default(5)
  betToExp    Int      @default(100)
  isOpen      Boolean  @default(true)
  cardImage   String?
  badgeImage  String?
  createdAt   DateTime @default(now())
}

model VipBenefit {
  id             String   @id @default(cuid())
  level          Int
  group          String // LEVEL or MY
  title          String
  description    String?
  image          String
  value          String?
  secondaryValue String?
  order          Int      @default(0)
  createdAt      DateTime @default(now())
}

model SiteConfig {
  id                 String   @id @default(cuid())
  brandName          String   @default("92 Glory0")
  announcement       String?  @db.Text
  announcementButton String?  @default("Detail")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ContentPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PromotionSetting {
  id              String   @id @default(cuid())
  commissionRate  Float    @default(0.1)
  rebateRate      Float    @default(0.15)
  customerService String?  @db.Text
  updatedAt       DateTime @updatedAt
}
