# Required: Hostinger/MySQL Prisma connection string
# Format:
# mysql://USERNAME:PASSWORD@HOST:3306/DATABASE_NAME?connection_limit=5&pool_timeout=20
DATABASE_URL="mysql://db_user:db_password@127.0.0.1:3306/db_name?connection_limit=5&pool_timeout=20"

# Required: JWT signing secret used by user auth
JWT_SECRET="change-this-to-a-long-random-secret"

# Required: Admin panel login credentials
ADMIN_PANEL_EMAIL="admin@clyrotech.com"
ADMIN_PANEL_PASSWORD="admin@786"

# Optional: disable automatic runtime seed in production
# ENABLE_RUNTIME_SEED="false"

# Optional: if hosting panel sets these automatically no need to define
# PORT="3000"
# HOST="0.0.0.0"
